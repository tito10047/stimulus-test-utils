{
  "name": "@tito10047/stimulus-test-utils",
  "version": "0.1.0",
  "description": "Zero-config, Testing-Library-flavoured test harness for Stimulus controllers.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tito10047/stimulus-test-utils.git"
  },
  "bugs": {
    "url": "https://github.com/tito10047/stimulus-test-utils/issues"
  },
  "author": {
    "name": "Jozef Môstka",
    "email": "jozef@mostka.sk",
    "url": "https://mostka.sk/"
  },
  "homepage": "https://tito10047.github.io/stimulus-test-utils/",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc --plugin typedoc-plugin-markdown --out docs/v0.1.0/api/generated --readme none --hideBreadcrumbs --hidePageHeader src/index.ts",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test -- --run && npm run build"
  },
  "peerDependencies": {
    "@hotwired/stimulus": "^3.2"
  },
  "devDependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^15.0.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.2.0",
    "typescript": "^5.4.0",
    "vitepress": "^1.3.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "stimulus",
    "hotwired",
    "testing",
    "test-utils",
    "testing-library",
    "vitest",
    "happy-dom"
  ]
}
